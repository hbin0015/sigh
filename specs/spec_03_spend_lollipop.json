{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Simple bar chart showing tourism spending by traveller type.",
  "width": "container",
  "height": 280,
  "data": {
    "values": [
      {
        "traveller_type": "All travellers",
        "spend_aud_billion": 192.4,
        "spending_growth_percent": 7.0
      },
      {
        "traveller_type": "Domestic overnight",
        "spend_aud_billion": 106.7,
        "spending_growth_percent": -1.9
      },
      {
        "traveller_type": "Domestic day",
        "spend_aud_billion": 46.4,
        "spending_growth_percent": 19.0
      },
      {
        "traveller_type": "International",
        "spend_aud_billion": 39.2,
        "spending_growth_percent": 19.0
      }
    ]
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 8,
    "opacity": 0.92
  },
  "encoding": {
    "y": {
      "field": "traveller_type",
      "type": "nominal",
      "title": null,
      "sort": "-x",
      "axis": {}
    },
    "x": {
      "field": "spend_aud_billion",
      "type": "quantitative",
      "title": "Spend (AUD billion)",
      "axis": {
        "tickCount": 5
      }
    },
    "color": {
      "field": "spending_growth_percent",
      "type": "quantitative",
      "title": "Growth (%)",
      "scale": {
        "scheme": "orangered"
      }
    },
    "tooltip": [
      {
        "field": "traveller_type",
        "type": "nominal",
        "title": "Traveller type"
      },
      {
        "field": "spend_aud_billion",
        "type": "quantitative",
        "title": "Spend (AUD billion)",
        "format": ".1f"
      },
      {
        "field": "spending_growth_percent",
        "type": "quantitative",
        "title": "Spending growth (%)",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "labelFont": "Arial",
      "labelFontSize": 12,
      "labelColor": "#49535b",
      "labelPadding": 6,
      "titleFont": "Arial",
      "titleFontSize": 12,
      "titleColor": "#273444",
      "titlePadding": 10,
      "grid": true,
      "gridColor": "#efd6b7",
      "gridOpacity": 0.7,
      "gridWidth": 1,
      "domain": false,
      "tickColor": "#d8b98d",
      "tickSize": 4
    },
    "axisX": {
      "labelAngle": 0
    },
    "axisY": {
      "grid": false
    },
    "legend": {
      "orient": "bottom",
      "direction": "horizontal",
      "titleFont": "Arial",
      "titleFontSize": 11,
      "titleColor": "#273444",
      "labelFont": "Arial",
      "labelFontSize": 12,
      "labelColor": "#49535b",
      "symbolSize": 120,
      "symbolStrokeWidth": 1.2,
      "padding": 6
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "fontWeight": "bold",
      "color": "#14213d",
      "subtitleFont": "Arial",
      "subtitleFontSize": 12,
      "subtitleColor": "#5d6470",
      "anchor": "start"
    },
    "range": {
      "category": [
        "#0077b6",
        "#f77f00",
        "#00a896",
        "#e85d75",
        "#9b5de5",
        "#fcbf49",
        "#2ec4b6",
        "#ff595e",
        "#1982c4",
        "#8ac926"
      ]
    }
  },
  "usermeta": {
    "style_note": "Restyled to match a warmer travel-guide page: soft paper background, muted axes, lighter gridlines, rounded marks, and consistent ocean/rust/sage palette.",
    "interactivity": "Use the slider to hide lower-growth traveller types. Hover bars for spend and growth."
  },
  "background": "transparent",
  "params": [
    {
      "name": "minSpendGrowth",
      "value": -5,
      "bind": {
        "input": "range",
        "min": -5,
        "max": 20,
        "step": 1,
        "name": "Only show growth above (%) "
      }
    }
  ],
  "transform": [
    {
      "filter": "datum.spending_growth_percent >= minSpendGrowth"
    }
  ]
}