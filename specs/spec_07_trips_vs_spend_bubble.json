{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bubble plot comparing trip volume and spend for traveller segments.",
  "width": "container",
  "height": 320,
  "background": "transparent",
  "data": {
    "url": "data/traveller_spend.csv"
  },
  "params": [
    {
      "name": "minSpend",
      "value": 0,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 200,
        "step": 10,
        "name": "Minimum spend (AUD b) "
      }
    },
    {
      "name": "travellerPick",
      "select": {
        "type": "point",
        "fields": [
          "traveller_type"
        ]
      },
      "bind": "legend"
    }
  ],
  "mark": {
    "type": "circle",
    "opacity": 0.84,
    "size": 520,
    "stroke": "white",
    "strokeWidth": 1.5
  },
  "encoding": {
    "x": {
      "field": "trips_million",
      "type": "quantitative",
      "title": "Trips (million)",
      "axis": {
        "tickCount": 5
      }
    },
    "y": {
      "field": "spend_aud_billion",
      "type": "quantitative",
      "title": "Spend (AUD billion)",
      "axis": {
        "tickCount": 5
      }
    },
    "color": {
      "field": "traveller_type",
      "type": "nominal",
      "title": "Click legend to focus",
      "scale": {
        "range": [
          "#0077b6",
          "#f77f00",
          "#00a896",
          "#e85d75"
        ]
      }
    },
    "opacity": {
      "condition": {
        "param": "travellerPick",
        "value": 0.9
      },
      "value": 0.16
    },
    "tooltip": [
      {
        "field": "traveller_type"
      },
      {
        "field": "trips_million",
        "title": "Trips (m)"
      },
      {
        "field": "spend_aud_billion",
        "title": "Spend (AUD b)"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "labelFont": "Arial",
      "labelFontSize": 12,
      "labelColor": "#49535b",
      "labelPadding": 6,
      "titleFont": "Arial",
      "titleFontSize": 12,
      "titleColor": "#273444",
      "titlePadding": 10,
      "grid": true,
      "gridColor": "#efd6b7",
      "gridOpacity": 0.7,
      "gridWidth": 1,
      "domain": false,
      "tickColor": "#d8b98d",
      "tickSize": 4
    },
    "axisX": {
      "labelAngle": 0
    },
    "axisY": {
      "grid": false
    },
    "legend": {
      "orient": "bottom",
      "direction": "horizontal",
      "titleFont": "Arial",
      "titleFontSize": 12,
      "titleColor": "#273444",
      "labelFont": "Arial",
      "labelFontSize": 12,
      "labelColor": "#49535b",
      "symbolSize": 120,
      "symbolStrokeWidth": 1.2,
      "padding": 6
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "fontWeight": "bold",
      "color": "#14213d",
      "subtitleFont": "Arial",
      "subtitleFontSize": 12,
      "subtitleColor": "#5d6470",
      "anchor": "start"
    },
    "range": {
      "category": [
        "#0077b6",
        "#f77f00",
        "#00a896",
        "#e85d75",
        "#9b5de5",
        "#fcbf49",
        "#2ec4b6",
        "#ff595e",
        "#1982c4",
        "#8ac926"
      ]
    }
  },
  "usermeta": {
    "style_note": "Restyled to match a warmer travel-guide page: soft paper background, muted axes, lighter gridlines, rounded marks, and consistent ocean/rust/sage palette.",
    "interactivity": "Use the spending slider to focus on larger segments. Click the legend to highlight one traveller type. Hover for trips and spend."
  },
  "transform": [
    {
      "filter": "datum.spend_aud_billion >= minSpend"
    }
  ]
}