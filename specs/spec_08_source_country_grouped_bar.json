{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Grouped bar chart of top source countries for March visitor arrivals.",
  "width": "container",
  "height": 360,
  "background": "transparent",
  "data": {
    "url": "data/source_countries_mar.csv"
  },
  "transform": [
    {
      "filter": "datum.year == 2019 || datum.year == 2026"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusTopLeft": 3,
    "cornerRadiusTopRight": 3,
    "cornerRadiusEnd": 6,
    "opacity": 0.92
  },
  "encoding": {
    "x": {
      "field": "country",
      "type": "nominal",
      "sort": "-y",
      "title": null,
      "axis": {
        "labelAngle": -25
      }
    },
    "xOffset": {
      "field": "year"
    },
    "y": {
      "field": "visitors",
      "type": "quantitative",
      "title": "Short-term visitors (March)",
      "axis": {
        "tickCount": 5
      }
    },
    "color": {
      "field": "year",
      "type": "nominal",
      "title": "Year",
      "scale": {
        "range": [
          "#b8b3aa",
          "#f77f00"
        ]
      }
    },
    "tooltip": [
      {
        "field": "country"
      },
      {
        "field": "year"
      },
      {
        "field": "visitors",
        "title": "Visitors"
      }
    ],
    "opacity": {
      "condition": {
        "param": "countryClick",
        "value": 0.95
      },
      "value": 0.22
    }
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "labelFont": "Arial",
      "labelFontSize": 12,
      "labelColor": "#49535b",
      "labelPadding": 6,
      "titleFont": "Arial",
      "titleFontSize": 12,
      "titleColor": "#273444",
      "titlePadding": 10,
      "grid": true,
      "gridColor": "#efd6b7",
      "gridOpacity": 0.7,
      "gridWidth": 1,
      "domain": false,
      "tickColor": "#d8b98d",
      "tickSize": 4
    },
    "axisX": {
      "labelAngle": 0
    },
    "axisY": {
      "grid": false
    },
    "legend": {
      "orient": "bottom",
      "direction": "horizontal",
      "titleFont": "Arial",
      "titleFontSize": 12,
      "titleColor": "#273444",
      "labelFont": "Arial",
      "labelFontSize": 12,
      "labelColor": "#49535b",
      "symbolSize": 120,
      "symbolStrokeWidth": 1.2,
      "padding": 6
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "fontWeight": "bold",
      "color": "#14213d",
      "subtitleFont": "Arial",
      "subtitleFontSize": 12,
      "subtitleColor": "#5d6470",
      "anchor": "start"
    },
    "range": {
      "category": [
        "#0077b6",
        "#f77f00",
        "#00a896",
        "#e85d75",
        "#9b5de5",
        "#fcbf49",
        "#2ec4b6",
        "#ff595e",
        "#1982c4",
        "#8ac926"
      ]
    }
  },
  "usermeta": {
    "style_note": "Restyled to match a warmer travel-guide page: soft paper background, muted axes, lighter gridlines, rounded marks, and consistent ocean/rust/sage palette.",
    "interactivity": "Click a country to focus its before/after bars; double-click to reset. Hover for exact visitor numbers."
  },
  "params": [
    {
      "name": "countryClick",
      "select": {
        "type": "point",
        "fields": [
          "country"
        ],
        "on": "click",
        "clear": "dblclick"
      }
    }
  ]
}